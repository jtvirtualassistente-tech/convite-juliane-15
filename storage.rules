rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isImage() {
      return request.resource.contentType.matches("image/.*")
        && request.resource.size < 8 * 1024 * 1024;
    }

    match /events/juliane-15/public/{fileName=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }

    match /events/juliane-15/gallery/{fileName=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }

    match /events/juliane-15/profile/{fileName=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }

    match /events/juliane-15/gifts/{fileName=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
