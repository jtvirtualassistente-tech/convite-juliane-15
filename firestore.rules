rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveGuestRead() {
      return resource.data.active == true
        && resource.data.eventId == "juliane-15";
    }

    function isValidGift(data) {
      return data.keys().hasOnly([
          "eventId",
          "name",
          "category",
          "description",
          "imageUrl",
          "linkUrl",
          "size",
          "color",
          "notes",
          "priority",
          "active",
          "createdAt",
          "updatedAt"
        ])
        && data.eventId == "juliane-15"
        && data.name is string
        && data.name.size() >= 2
        && data.name.size() <= 120
        && data.category is string
        && data.category.size() <= 80
        && data.description is string
        && data.description.size() <= 500
        && data.imageUrl is string
        && data.imageUrl.size() <= 500
        && data.linkUrl is string
        && data.linkUrl.size() <= 500
        && data.size is string
        && data.size.size() <= 80
        && data.color is string
        && data.color.size() <= 80
        && data.notes is string
        && data.notes.size() <= 500
        && data.priority is string
        && data.priority.size() <= 40
        && data.active is bool;
    }

    match /admins/{uid} {
      allow read: if isAdmin() && request.auth.uid == uid;
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if eventId == "juliane-15";
      allow write: if isAdmin();
    }

    match /guests/{guestId} {
      allow get, list: if isAdmin() || isActiveGuestRead();
      allow create, delete: if isAdmin();

      allow update: if isAdmin()
        || (
          isActiveGuestRead()
          && request.time < timestamp.date(2026, 8, 21)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "mainGuestName",
            "phone",
            "companionNames",
            "status",
            "confirmedAt",
            "updatedAt"
          ])
          && request.resource.data.status in ["confirmed", "declined"]
          && request.resource.data.companionNames.size() <= resource.data.maxCompanions
        );

      match /companions/{companionId} {
        allow read, write: if isAdmin();
      }
    }

    match /rsvps/{rsvpId} {
      allow create: if request.resource.data.eventId == "juliane-15"
        && request.resource.data.keys().hasOnly([
          "eventId",
          "name",
          "phone",
          "willAttend",
          "people",
          "status",
          "totalPeople",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.phone is string
        && (
          request.resource.data.phone.size() == 0
          || request.resource.data.phone.size() >= 10
        )
        && request.resource.data.willAttend is bool
        && request.resource.data.people is list
        && request.resource.data.people.size() <= 300
        && request.resource.data.status in ["confirmed", "declined"]
        && request.resource.data.totalPeople is int
        && request.resource.data.totalPeople <= 300;

      allow read: if resource.data.eventId == "juliane-15";
      allow update, delete: if isAdmin();
    }

    match /content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /giftCategories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gifts/{document=**} {
      allow read: if (
        resource.data.eventId == "juliane-15"
        && resource.data.active == true
      ) || isAdmin();
      allow create: if isValidGift(request.resource.data);
      allow update: if resource.data.eventId == "juliane-15"
        && isValidGift(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "eventId",
          "name",
          "category",
          "description",
          "imageUrl",
          "linkUrl",
          "size",
          "color",
          "notes",
          "priority",
          "active",
          "createdAt",
          "updatedAt"
        ]);
      allow delete: if false;
    }

    match /views/{viewId} {
      allow read: if resource.data.eventId == "juliane-15";
      allow create, update: if request.resource.data.eventId == "juliane-15"
        && request.resource.data.keys().hasOnly([
          "eventId",
          "visitorId",
          "deviceType",
          "userAgent",
          "createdAt",
          "lastSeenAt"
        ])
        && request.resource.data.visitorId is string
        && request.resource.data.visitorId.size() >= 8
        && request.resource.data.visitorId.size() <= 120
        && request.resource.data.deviceType in ["Celular", "Tablet", "Computador"]
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 300;
      allow delete: if false;
    }

    match /gallery/{document=**} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }
  }
}
